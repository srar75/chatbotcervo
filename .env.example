# WATI API Configuration
WATI_API_URL=https://live-mt-server.wati.io/YOUR_TENANT_ID
WATI_API_TOKEN=your_wati_token_here

# KIU API Configuration (Sistema de Reservas de Vuelos)
KIU_API_URL=https://api.cervotravel.app/v1
KIU_API_TOKEN=your_kiu_token_here

# Z.AI Configuration - GLM-4.6
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_URL=https://api.z.ai/api/paas/v4/chat/completions
ZAI_MODEL=glm-4.6

# OpenRouter AI Configuration (Backup)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Testing Configuration
TESTING_MODE=false
ALLOWED_PHONE=

# Flask Configuration
FLASK_PORT=5000
FLASK_DEBUG=true

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
